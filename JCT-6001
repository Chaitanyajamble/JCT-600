        system_prompt=LEAD_SCORING_SYSTEM,
        user_message=f"Lead data:\n{json.dumps(lead_data, indent=2)}",
        temperature=0.3,
        max_tokens=300,
    )
    try:
        clean = raw.strip().lstrip("```json").rstrip("```").strip()
