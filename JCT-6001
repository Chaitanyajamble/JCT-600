    """
    Classify customer intent to route to the correct department.
    Returns a JSON-like dict with intent label and confidence.
    """
    import json

    system = """
    Classify the following customer message into exactly ONE of these intents:
    - service_booking
    - warranty_enquiry
    - finance_enquiry
    - part_exchange
    - complaint
    - general_information
    - test_drive_booking
