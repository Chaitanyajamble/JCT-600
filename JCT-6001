from fastapi import APIRouter, HTTPException
from fastapi.responses import StreamingResponse
from pydantic import BaseModel, Field

router = APIRouter()


# ── Request / Response Models ─────────────────────────────────────────────────

class ChatMessage(BaseModel):
    role: str = Field(..., example="user")
    content: str = Field(..., example="I'd like to book my car in for a service.")


class ChatRequest(BaseModel):
    message: str = Field(..., min_length=1, example="What are your opening hours?")
    conversation_history: list[ChatMessage] | None = None


class ChatResponse(BaseModel):
    reply: str
    assistant: str = "Jamie – JCT 600 Support"


class IntentRequest(BaseModel):
    message: str = Field(..., min_length=3, example="I want to trade in my old car")


class IntentResponse(BaseModel):
    intent: str
    confidence: float
    summary: str


# ── Endpoints ─────────────────────────────────────────────────────────────────

@router.post("/chat", response_model=ChatResponse,
             summary="Send a message to the JCT 600 support chatbot")
async def chat(request: ChatRequest):
    """
    Multi-turn customer support chat. Pass the full conversation_history
    on each request to maintain context.
    """
    try:
        history = (
            [msg.model_dump() for msg in request.conversation_history]
            if request.conversation_history else None
        )
        reply = await get_support_reply(request.message, history)
        return {"reply": reply, "assistant": "Jamie – JCT 600 Support"}
    except Exception as exc:
        raise HTTPException(status_code=500, detail=str(exc))


@router.post("/chat/stream", summary="Streaming chat response (Server-Sent Events)")
async def chat_stream(request: ChatRequest):
    """
    Same as /chat but streams the reply token-by-token using Server-Sent Events.
    Ideal for real-time typing-indicator UX.
    """
    try:
        history = (
            [msg.model_dump() for msg in request.conversation_history]
            if request.conversation_history else None
        )

        async def sse_generator():
            async for chunk in stream_support_reply(request.message, history):
                yield f"data: {chunk}\n\n"
            yield "data: [DONE]\n\n"

        return StreamingResponse(sse_generator(), media_type="text/event-stream")
    except Exception as exc:
        raise HTTPException(status_code=500, detail=str(exc))


@router.post("/intent", response_model=IntentResponse,
             summary="Classify the intent of a customer message")
async def classify_intent(request: IntentRequest):
    """
    Classifies the customer's message intent for routing to the correct
    JCT 600 department or workflow.
    """
    try:
        result = await classify_support_intent(request.message)
        return result
    except Exception as exc:
        raise HTTPException(status_code=500, detail=str(exc))
