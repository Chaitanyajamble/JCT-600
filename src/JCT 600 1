@dataclass
class FinanceQuote:
    """
    Input parameters for generating a vehicle finance quote.
    Supports PCP, HP, and PCH (lease) products.
    """
    customer_id:    str
    vehicle_id:     str
    finance_type:   FinanceType
    vehicle_price:  float      # Agreed selling price in GBP
    deposit:        float      # Customer deposit
    term_months:    int        # e.g. 24, 36, 48, 60
    annual_mileage: int        # Required for PCP/PCH
    part_exchange_value: float = 0.0   # Part-ex vehicle value
    part_exchange_outstanding: float = 0.0   # Finance outstanding on PX


class FinanceQuotation:
    """Generate and manage vehicle finance quotes for JCT600 customers."""

    def generate_quote(self, quote: FinanceQuote) -> dict:
        """
        Request a finance quote from the lender (e.g. BMW Financial Services,
        Volkswagen Financial Services, Black Horse).
        """
        payload = asdict(quote)
        payload["finance_type"] = quote.finance_type.value
        result = api_request("POST", "/finance/quotes", payload)

        if "quote_id" in result:
            r = result
            print(f"[FINANCE] {quote.finance_type.value.upper()} Quote generated:")
            print(f"  Vehicle Price : £{quote.vehicle_price:,.2f}")
            print(f"  Deposit       : £{quote.deposit:,.2f}")
            print(f"  Term          : {quote.term_months} months")
            print(f"  Monthly Payment: £{r.get('monthly_payment', 0):,.2f}")
            print(f"  APR           : {r.get('apr', 0):.1f}%")
            print(f"  Total Cost    : £{r.get('total_cost', 0):,.2f}")
            if quote.finance_type == FinanceType.PCP:
                print(f"  Final Payment  : £{r.get('optional_final_payment', 0):,.2f} (GFV)")
            print(f"  Quote ID       : {r['quote_id']}")
        return result

    def compare_finance_options(self, vehicle_id: str, vehicle_price: float,
                                 deposit: float, term_months: int) -> List[dict]:
        """
        Generate and compare PCP, HP, and PCH quotes side by side.

        Returns:
            List of quote dicts for each product type.
        """
        print(f"[FINANCE] Comparing options for Vehicle {vehicle_id} "
              f"| Price £{vehicle_price:,.0f} | Deposit £{deposit:,.0f} | {term_months}mo")
        quotes = []
        for ft in [FinanceType.PCP, FinanceType.HP, FinanceType.PCH]:
            quote = FinanceQuote(
                customer_id="COMP-QUOTE",
                vehicle_id=vehicle_id,
                finance_type=ft,
                vehicle_price=vehicle_price,
                deposit=deposit,
                term_months=term_months,
                annual_mileage=10000,
            )
            result = self.generate_quote(quote)
            result["finance_type"] = ft.value
            quotes.append(result)
        return quotes

    def submit_finance_application(self, quote_id: str, customer_id: str) -> dict:
        """Submit a finance application based on an accepted quote."""
        payload = {
            "quote_id":    quote_id,
            "customer_id": customer_id,
            "submitted_at": str(datetime.now()),
        }
        result = api_request("POST", "/finance/applications", payload)
        print(f"[FINANCE] Application submitted: "
              f"App ID={result.get('application_id')} | "
              f"Status={result.get('decision', 'Pending')}")
        return result


