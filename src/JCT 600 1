@dataclass
class VehicleSaleOrder:
    """Represents a complete vehicle sale transaction."""
    customer_id:        str
    vehicle_id:         str
    sale_price:         float
    finance_quote_id:   Optional[str]     # None if cash purchase
    finance_type:       FinanceType
    salesperson_id:     str
    branch:             str
    part_exchange_reg:  Optional[str] = None
    part_exchange_value: float = 0.0
    accessories:        List[dict] = field(default_factory=list)  # [{name, price}]
    warranty_package:   str = "standard"   # 'standard', 'extended_1yr', 'extended_3yr'
    delivery_date:      str = ""

    @property
    def accessories_total(self) -> float:
        return sum(a.get("price", 0) for a in self.accessories)

    @property
    def total_order_value(self) -> float:
        return self.sale_price + self.accessories_total

    @property
    def net_deposit_needed(self) -> float:
        return max(0, self.total_order_value - self.part_exchange_value)


class SalesOrderProcessing:
    """JCT600 Sales Order Processing — from deal to delivery."""

    def create_sale_order(self, order: VehicleSaleOrder) -> dict:
        """
        Create a vehicle sale order (deal sheet).

        Covers cash, PCP, HP, and PCH transactions.
        """
        payload = {
            "customer_id":        order.customer_id,
            "vehicle_id":         order.vehicle_id,
            "sale_price":         order.sale_price,
            "finance_quote_id":   order.finance_quote_id,
            "finance_type":       order.finance_type.value,
            "salesperson_id":     order.salesperson_id,
            "branch":             order.branch,
            "part_exchange_reg":  order.part_exchange_reg,
            "part_exchange_value": order.part_exchange_value,
            "accessories":        order.accessories,
            "accessories_total":  order.accessories_total,
            "warranty_package":   order.warranty_package,
            "total_order_value":  order.total_order_value,
            "delivery_date":      order.delivery_date,
            "order_date":         str(date.today()),
        }
        result = api_request("POST", "/sales/orders", payload)
        if "order_id" in result:
            print(f"[SALES] Order created: ID={result['order_id']} | "
                  f"Vehicle={order.vehicle_id} | Customer={order.customer_id} | "
                  f"Total=£{order.total_order_value:,.2f} | "
                  f"Finance={order.finance_type.value.upper()}")
        return result

    def get_order_status(self, order_id: str) -> dict:
        """Check the current status of a sale order."""
        result = api_request("GET", f"/sales/orders/{order_id}/status")
        print(f"[SALES] Order {order_id} Status: {result.get('status')} | "
              f"Stage: {result.get('stage')} | "
              f"Delivery: {result.get('expected_delivery', 'TBC')}")
        return result

    def schedule_vehicle_delivery(self, order_id: str, delivery_date: str,
                                   delivery_time: str, driver_id: str) -> dict:
        """Schedule the final vehicle handover/delivery."""
        payload = {
            "delivery_date": delivery_date,
            "delivery_time": delivery_time,
            "driver_id":     driver_id,
        }
        result = api_request("POST", f"/sales/orders/{order_id}/delivery", payload)
        print(f"[SALES] Delivery scheduled: Order {order_id} | "
              f"{delivery_date} @ {delivery_time} | Driver: {driver_id}")
        return result

    def complete_handover(self, order_id: str, customer_signature: str,
                           handover_notes: str) -> dict:
        """
        Record vehicle handover completion — customer signs and takes delivery.

        Args:
            order_id           : Sale order ID
            customer_signature : Base64-encoded signature or digital ref
            handover_notes     : Handover checklist notes
        """
        payload = {
            "customer_signature": customer_signature,
            "handover_notes":    handover_notes,
            "handover_date":     str(date.today()),
            "status":            "delivered",
        }
        result = api_request("POST", f"/sales/orders/{order_id}/handover", payload)
        print(f"[SALES] Handover complete for order {order_id} — "
              f"Vehicle delivered to customer.")
        return result


