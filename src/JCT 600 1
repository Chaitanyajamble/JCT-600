@dataclass
class TestDriveBooking:
    """Represents a test drive appointment."""
    customer_id:  str
    vehicle_id:   str
    branch:       str
    preferred_date: str    # 'YYYY-MM-DD'
    preferred_time: str    # 'HH:MM'
    duration_mins: int = 30
    notes:        str = ""


class TestDriveManagement:
    """Manage test drive bookings at JCT600 branches."""

    def book_test_drive(self, booking: TestDriveBooking) -> dict:
        """Schedule a test drive for a customer."""
        result = api_request("POST", "/test-drives/book", asdict(booking))
        if "booking_ref" in result:
            print(f"[TEST DRIVE] Booked: Ref={result['booking_ref']} | "
                  f"Customer={booking.customer_id} | Vehicle={booking.vehicle_id} | "
                  f"{booking.preferred_date} @ {booking.preferred_time} | "
                  f"Branch={booking.branch}")
        return result

    def get_available_slots(self, branch: str, date: str) -> List[dict]:
        """
        Get available test drive time slots at a branch for a given date.

        Args:
            branch : Branch name or code
            date   : Date string 'YYYY-MM-DD'
        """
        result = api_request("GET", f"/test-drives/slots?branch={branch}&date={date}")
        slots  = result.get("slots", [])
        print(f"[TEST DRIVE] Available slots at {branch} on {date}: {len(slots)}")
        for slot in slots:
            print(f"  • {slot['time']} — {slot.get('vehicle_available', 'Any')} "
                  f"({'Available' if slot.get('available') else 'Booked'})")
        return slots

    def cancel_test_drive(self, booking_ref: str, reason: str) -> dict:
        """Cancel an existing test drive booking."""
        payload = {"reason": reason, "cancelled_at": str(datetime.now())}
        result  = api_request("DELETE", f"/test-drives/{booking_ref}", payload)
        print(f"[TEST DRIVE] Booking {booking_ref} cancelled: {reason}")
        return result

    def complete_test_drive(self, booking_ref: str, feedback: str, interested: bool) -> dict:
        """Record test drive completion and customer feedback."""
        payload = {
            "status":         "completed",
            "customer_feedback": feedback,
            "interested_in_purchase": interested,
            "completed_at":   str(datetime.now()),
        }
        result = api_request("PATCH", f"/test-drives/{booking_ref}/complete", payload)
        print(f"[TEST DRIVE] {booking_ref} completed | "
              f"Interested in purchase: {'Yes' if interested else 'No'}")
        return result


