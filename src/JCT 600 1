    BRANCHES = [
        "Bradford", "Leeds", "Sheffield", "York",
        "Harrogate", "Huddersfield", "Rotherham",
    ]

    def get_branch_sales_summary(self, branch: str, month: int, year: int) -> dict:
        """Monthly sales summary for a branch."""
        result = api_request("GET",
            f"/reporting/sales?branch={branch}&month={month}&year={year}")
        if "summary" in result:
            s = result["summary"]
            print(f"[REPORT] {branch} Sales {month}/{year}: "
                  f"New={s.get('new_vehicles_sold', 0)} | "
                  f"Used={s.get('used_vehicles_sold', 0)} | "
                  f"Revenue=£{s.get('total_revenue', 0):,.0f} | "
                  f"Finance Penetration={s.get('finance_penetration', 0):.0f}%")
        return result

    def get_group_dashboard(self) -> dict:
        """Retrieve group-wide KPIs across all JCT600 branches."""
        result = api_request("GET", "/reporting/group-dashboard")
        if "kpis" in result:
            k = result["kpis"]
            print(f"[REPORT] JCT600 Group KPIs:")
            print(f"  • Total Vehicles Sold (MTD)  : {k.get('vehicles_sold_mtd', 0)}")
            print(f"  • Total Revenue (MTD)        : £{k.get('revenue_mtd', 0):,.0f}")
            print(f"  • Finance Penetration        : {k.get('finance_penetration', 0):.0f}%")
            print(f"  • Service Jobs (MTD)         : {k.get('service_jobs_mtd', 0)}")
            print(f"  • Customer Satisfaction (NPS): {k.get('nps_score', 0)}")
            print(f"  • Active Test Drive Bookings : {k.get('test_drive_bookings', 0)}")
        return result

    def get_stock_turn_report(self, branch: str = None) -> dict:
        """
        Analyse stock turn rate — how many days vehicles are sitting unsold.

        Args:
            branch : Specific branch or None for group-wide
        """
        endpoint = "/reporting/stock-turn"
        if branch:
            endpoint += f"?branch={branch}"
        result = api_request("GET", endpoint)
        if "analysis" in result:
            a = result["analysis"]
            print(f"[REPORT] Stock Turn{f' ({branch})' if branch else ' (Group)'}:")
            print(f"  • Avg Days in Stock (New)  : {a.get('avg_days_new', 0):.0f} days")
            print(f"  • Avg Days in Stock (Used) : {a.get('avg_days_used', 0):.0f} days")
            print(f"  • Vehicles > 60 days       : {a.get('aged_stock_count', 0)}")
        return result


