@dataclass
class ServiceBooking:
    """Represents a vehicle service booking."""
    customer_id:    str
    vehicle_reg:    str
    service_type:   ServiceType
    branch:         str
    preferred_date: str
    preferred_time: str
    courtesy_car:   bool = False
    collection_delivery: bool = False   # Collect & return service
    customer_notes: str = ""
    mileage:        int = 0


class ServiceAftersales:
    """JCT600 Service & Aftersales — MOT, servicing, repairs, and tyres."""

    def book_service(self, booking: ServiceBooking) -> dict:
        """Book a vehicle service appointment."""
        payload = asdict(booking)
        payload["service_type"] = booking.service_type.value
        result = api_request("POST", "/service/bookings", payload)
        if "booking_ref" in result:
            print(f"[SERVICE] Booking confirmed: Ref={result['booking_ref']} | "
                  f"Reg={booking.vehicle_reg} | "
                  f"Type={booking.service_type.value.replace('_', ' ').title()} | "
                  f"{booking.preferred_date} @ {booking.preferred_time} | "
                  f"Branch={booking.branch}")
            if booking.courtesy_car:
                print(f"  ↳ Courtesy car requested: {'Confirmed' if result.get('courtesy_car_confirmed') else 'Subject to availability'}")
        return result

    def get_mot_reminders(self, days_ahead: int = 30) -> List[dict]:
        """
        Retrieve customers with MOT due within the specified number of days.
        Used for proactive outreach and re-booking campaigns.

        Args:
            days_ahead : Look-ahead window in days
        """
        result    = api_request("GET", f"/service/mot-reminders?days={days_ahead}")
        reminders = result.get("reminders", [])
        print(f"[SERVICE] MOT due in next {days_ahead} days: {len(reminders)} vehicle(s)")
        for r in reminders[:5]:
            print(f"  • {r.get('vehicle_reg')} | {r.get('customer_name')} | "
                  f"MOT Expiry: {r.get('mot_expiry')} | "
                  f"Branch: {r.get('last_branch')}")
        return reminders

    def create_job_card(self, booking_ref: str, technician_id: str,
                         additional_work: List[str] = None) -> dict:
        """
        Create a workshop job card when the vehicle arrives for service.

        Args:
            booking_ref      : Service booking reference
            technician_id    : Assigned technician ID
            additional_work  : Any extra work identified on vehicle check-in
        """
        payload = {
            "booking_ref":    booking_ref,
            "technician_id":  technician_id,
            "check_in_time":  str(datetime.now()),
            "additional_work": additional_work or [],
        }
        result = api_request("POST", "/service/job-cards", payload)
        print(f"[SERVICE] Job card created: {result.get('job_card_number')} | "
              f"Technician: {technician_id}")
        return result

    def complete_service(self, job_card_number: str, work_done: str,
                          labour_cost: float, parts_cost: float) -> dict:
        """Record service completion and generate invoice."""
        payload = {
            "job_card_number": job_card_number,
            "work_done":       work_done,
            "labour_cost":     labour_cost,
            "parts_cost":      parts_cost,
            "vat_rate":        20.0,   # UK standard VAT
            "completed_at":    str(datetime.now()),
        }
        total_ex_vat = labour_cost + parts_cost
        total_inc_vat = total_ex_vat * 1.20
        result = api_request("POST", f"/service/job-cards/{job_card_number}/complete", payload)
        print(f"[SERVICE] Job {job_card_number} completed: "
              f"Labour=£{labour_cost:,.2f} | Parts=£{parts_cost:,.2f} | "
              f"Total (inc. VAT)=£{total_inc_vat:,.2f} | "
              f"Invoice: {result.get('invoice_number')}")
        return result


