# MODULE 1: VEHICLE INVENTORY
# ═════════════════════════════════════════════
@dataclass
class Vehicle:
    """Represents a vehicle in JCT600's stock."""
    vin:            str                 # Vehicle Identification Number (17 chars)
    registration:   str                 # UK registration plate, e.g. 'AB12 CDE'
    make:           str                 # e.g. 'BMW', 'Volkswagen', 'Audi'
    model:          str                 # e.g. '3 Series', 'Golf', 'A4'
    variant:        str                 # Trim level, e.g. 'Sport', 'SE', 'M Sport'
    year:           int
    colour:         str
    mileage:        int                 # Miles
    fuel_type:      FuelType
    transmission:   str                 # 'manual' or 'automatic'
    condition:      VehicleCondition
    list_price:     float               # OTR (On The Road) price in GBP
    offer_price:    float               # Discounted/offer price
    branch:         str                 # Dealership location, e.g. 'Bradford', 'Leeds'
    co2_gkm:        int                 # CO2 emissions g/km
    mpg:            float               # Official MPG
    mot_expiry:     Optional[str] = None
    service_history: bool = True


class VehicleInventory:
    """JCT600 Vehicle Inventory management — search, add, update stock."""

    def add_vehicle(self, vehicle: Vehicle) -> dict:
        """Add a new vehicle to JCT600's stock system."""
        payload = asdict(vehicle)
        # Convert Enum values to strings for JSON serialisation
        payload["fuel_type"]  = vehicle.fuel_type.value
        payload["condition"]  = vehicle.condition.value
        result = api_request("POST", "/vehicles", payload)
        if "vehicle_id" in result:
            print(f"[INVENTORY] Vehicle added: {vehicle.year} {vehicle.make} "
                  f"{vehicle.model} ({vehicle.registration}) | "
                  f"Stock ID: {result['vehicle_id']} | £{vehicle.offer_price:,.0f}")
        return result

    def search_vehicles(
        self,
        make: str = None,
        model: str = None,
        fuel_type: str = None,
        condition: str = None,
        max_price: float = None,
        max_mileage: int = None,
        branch: str = None,
    ) -> List[dict]:
        """
        Search the vehicle stock with optional filters.

        Returns:
            List of matching vehicle dicts.
        """
        params = []
        if make:        params.append(f"make={make}")
        if model:       params.append(f"model={model}")
        if fuel_type:   params.append(f"fuel_type={fuel_type}")
        if condition:   params.append(f"condition={condition}")
        if max_price:   params.append(f"max_price={max_price}")
        if max_mileage: params.append(f"max_mileage={max_mileage}")
        if branch:      params.append(f"branch={branch}")

        query   = "?" + "&".join(params) if params else ""
        result  = api_request("GET", f"/vehicles/search{query}")
        vehicles = result.get("vehicles", [])

        print(f"[INVENTORY] Search returned {len(vehicles)} vehicle(s):")
        for v in vehicles[:5]:
            print(f"  • {v.get('year')} {v.get('make')} {v.get('model')} "
                  f"| {v.get('mileage', 0):,} miles | £{v.get('offer_price', 0):,.0f} "
                  f"| {v.get('branch')}")
        return vehicles

    def get_vehicle_details(self, vehicle_id: str) -> dict:
        """Retrieve full details of a specific vehicle by stock ID."""
        result = api_request("GET", f"/vehicles/{vehicle_id}")
        if "vin" in result:
            print(f"[INVENTORY] Vehicle {vehicle_id}: "
                  f"{result['year']} {result['make']} {result['model']} "
                  f"| VIN: {result['vin']} | £{result.get('offer_price', 0):,.0f}")
        return result

    def update_vehicle_price(self, vehicle_id: str, new_price: float, reason: str) -> dict:
        """Update the offer price of a vehicle."""
        payload = {
            "offer_price":    new_price,
            "price_change_reason": reason,
            "updated_at":     str(datetime.now()),
        }
        result = api_request("PATCH", f"/vehicles/{vehicle_id}/price", payload)
        print(f"[INVENTORY] Price updated for {vehicle_id}: £{new_price:,.0f} ({reason})")
        return result

    def mark_as_sold(self, vehicle_id: str, sale_date: str) -> dict:
        """Mark a vehicle as sold and remove from available stock."""
        payload = {"status": "sold", "sale_date": sale_date}
        result  = api_request("PATCH", f"/vehicles/{vehicle_id}/status", payload)
        print(f"[INVENTORY] Vehicle {vehicle_id} marked as SOLD on {sale_date}")
        return result


