# MODULE 2: CUSTOMER MANAGEMENT
# ═════════════════════════════════════════════
@dataclass
class Customer:
    """Represents a JCT600 customer (individual or business)."""
    title:         str    # 'Mr', 'Mrs', 'Ms', 'Dr'
    first_name:    str
    last_name:     str
    email:         str
    mobile:        str
    address_line1: str
    city:          str
    postcode:      str    # UK postcode, e.g. 'BD1 1AA'
    date_of_birth: str    # Required for finance applications
    gdpr_consent:  bool   # GDPR marketing consent
    customer_type: str = "individual"   # 'individual' or 'business'
    company_name:  str = ""
    driving_licence: str = ""


class CustomerManagement:
    """JCT600 Customer Relationship Management."""

    def create_customer(self, customer: Customer) -> dict:
        """Register a new customer in the DMS."""
        result = api_request("POST", "/customers", asdict(customer))
        if "customer_id" in result:
            print(f"[CRM] Customer created: {customer.title} {customer.first_name} "
                  f"{customer.last_name} | ID: {result['customer_id']} | "
                  f"{customer.postcode}")
        return result

    def search_customers(self, query: str) -> List[dict]:
        """
        Search customers by name, email, or postcode.

        Args:
            query : Search string
        """
        result    = api_request("GET", f"/customers/search?q={query}")
        customers = result.get("customers", [])
        print(f"[CRM] Search '{query}': {len(customers)} customer(s) found")
        return customers

    def get_customer_history(self, customer_id: str) -> dict:
        """
        Retrieve a customer's full interaction history including
        purchases, service visits, and enquiries.
        """
        result = api_request("GET", f"/customers/{customer_id}/history")
        h = result.get("history", {})
        print(f"[CRM] Customer {customer_id} history: "
              f"Purchases={h.get('purchases', 0)} | "
              f"Service Visits={h.get('service_visits', 0)} | "
              f"Test Drives={h.get('test_drives', 0)} | "
              f"Lifetime Value=£{h.get('lifetime_value', 0):,.0f}")
        return result

    def update_gdpr_preferences(self, customer_id: str, consent: bool) -> dict:
        """Update a customer's GDPR marketing consent preferences."""
        payload = {
            "gdpr_consent":  consent,
            "consent_date":  str(date.today()),
        }
        result = api_request("PATCH", f"/customers/{customer_id}/gdpr", payload)
        status = "Opted IN" if consent else "Opted OUT"
        print(f"[CRM] Customer {customer_id} GDPR marketing: {status}")
        return result


