"""
=============================================================================
JCT600 Automotive Retail — Sample Python Integration Code
Website: https://www.jct600.co.uk
Description: Demonstrates a Python integration layer for a JCT600-style
             automotive retail platform, covering Vehicle Inventory,
             Customer Management, Test Drive Bookings, Finance Quotes,
             Service Scheduling, and Sales Order Processing.

NOTE: JCT600 does not expose a public REST API. This code models the domain
      using a realistic RESTful API design typical of modern automotive DMS
      (Dealer Management Systems) such as those used by franchised dealers.
      Replace BASE_URL and API_KEY with actual credentials if integrating
      with a live DMS (e.g., Keyloop, CDK, Reynolds & Reynolds).
=============================================================================
"""

import requests
import json
from datetime import datetime, date, timedelta
from dataclasses import dataclass, field, asdict
from typing import Optional, List
from enum import Enum

# ─────────────────────────────────────────────
# CONFIGURATION
# ─────────────────────────────────────────────
BASE_URL = "https://api.jct600.co.uk/v1"    # Replace with actual DMS API base
API_KEY  = "YOUR_API_KEY_HERE"

HEADERS = {
    "Content-Type":  "application/json",
    "Authorization": f"Bearer {API_KEY}",
    "Accept":        "application/json",
    "X-Dealer-Code": "JCT600-BRADFORD",     # Dealer group code
}


# ─────────────────────────────────────────────
# ENUMS
# ─────────────────────────────────────────────
class VehicleCondition(str, Enum):
    NEW        = "new"
    USED       = "used"
    APPROVED_USED = "approved_used"   # Manufacturer-certified pre-owned


class FuelType(str, Enum):
    PETROL   = "petrol"
    DIESEL   = "diesel"
    HYBRID   = "hybrid"
    ELECTRIC = "electric"
    PHEV     = "phev"   # Plug-in Hybrid


class ServiceType(str, Enum):
    FULL_SERVICE     = "full_service"
    INTERIM_SERVICE  = "interim_service"
    MOT              = "mot"
    REPAIR           = "repair"
    RECALL           = "recall"
    TYRE_REPLACEMENT = "tyre_replacement"


class FinanceType(str, Enum):
    PCP  = "pcp"    # Personal Contract Purchase
    HP   = "hp"     # Hire Purchase
    PCH  = "pch"    # Personal Contract Hire (Lease)
    CASH = "cash"


# ─────────────────────────────────────────────
# HELPER — Generic HTTP request handler
# ─────────────────────────────────────────────
def api_request(method: str, endpoint: str, payload: dict = None) -> dict:
    """
    Generic API request wrapper for JCT600 DMS.

    Args:
        method   : HTTP method — 'GET', 'POST', 'PUT', 'PATCH', 'DELETE'
        endpoint : API endpoint path (e.g. '/vehicles/search')
        payload  : Optional request body as dict

    Returns:
        Parsed JSON response as dict, or error dict.
    """
    url = f"{BASE_URL}{endpoint}"
    try:
        response = requests.request(
            method=method.upper(),
            url=url,
            headers=HEADERS,
            json=payload,
            timeout=30,
        )
        response.raise_for_status()
        return response.json()
    except requests.exceptions.HTTPError as e:
        return {"error": f"HTTP error: {e}", "status_code": response.status_code}
    except requests.exceptions.ConnectionError:
        return {"error": "Connection failed. Check BASE_URL and network."}
    except requests.exceptions.Timeout:
        return {"error": "Request timed out."}
    except Exception as e:
        return {"error": str(e)}


