from fastapi import APIRouter, Depends
from sqlalchemy.orm import Session
from database import get_db
from models.finance import PartExchangeValuation, FinanceApplication
from schemas.finance import (
    PartExchangeRequest, PartExchangeResponse,
    FinanceCalculatorRequest, FinanceCalculatorResponse,
    FinanceApplicationRequest
)

router = APIRouter(prefix="/api/v1/finance", tags=["Finance"])

# Part-exchange valuation estimator (simplified)
CONDITION_MULTIPLIER = {
    "Excellent": 1.0, "Good": 0.85, "Fair": 0.70, "Poor": 0.50
}
BASE_VALUES = {
    "Audi": 15000, "BMW": 16000, "Mercedes-Benz": 17000,
    "Volkswagen": 12000, "Ford": 9000, "Vauxhall": 7000
}

@router.post("/part-exchange", response_model=PartExchangeResponse)
def get_part_exchange_valuation(data: PartExchangeRequest, db: Session = Depends(get_db)):
    base = BASE_VALUES.get(data.make, 10000)
    age_factor = max(0.3, 1 - ((2025 - (data.year or 2020)) * 0.08))
    mileage_factor = max(0.5, 1 - ((data.mileage or 30000) / 200000))
    condition_factor = CONDITION_MULTIPLIER.get(data.condition, 0.75)
    estimated = round(base * age_factor * mileage_factor * condition_factor, 2)

    valuation = PartExchangeValuation(
        customer_name=data.customer_name,
        customer_email=data.customer_email,
        vehicle_reg=data.vehicle_reg,
        make=data.make, model=data.model,
        year=data.year, mileage=data.mileage,
        condition=data.condition, estimated_value=estimated
    )
    db.add(valuation)
    db.commit()

    return PartExchangeResponse(
        estimated_value=estimated,
        condition=data.condition,
        message=f"Estimated part-exchange value: £{estimated:,.2f}. "
                "A JCT600 adviser will contact you to confirm."
    )

@router.post("/calculator", response_model=FinanceCalculatorResponse)
def finance_calculator(data: FinanceCalculatorRequest):
    loan_amount = data.vehicle_price - data.deposit
    monthly_rate = (data.annual_rate / 100) / 12
    n = data.term_months
    if monthly_rate > 0:
        monthly = loan_amount * (monthly_rate * (1 + monthly_rate)**n) / \
                  ((1 + monthly_rate)**n - 1)
    else:
        monthly = loan_amount / n
    monthly = round(monthly, 2)
    total_payable = round(monthly * n + data.deposit, 2)
    total_interest = round(total_payable - data.vehicle_price, 2)
    return FinanceCalculatorResponse(
        vehicle_price=data.vehicle_price,
        deposit=data.deposit,
        loan_amount=round(loan_amount, 2),
        term_months=n,
        annual_rate=data.annual_rate,
        monthly_payment=monthly,
        total_payable=total_payable,
        total_interest=total_interest
    )

@router.post("/apply", status_code=201)
def submit_finance_application(data: FinanceApplicationRequest, db: Session = Depends(get_db)):
    calc = finance_calculator(FinanceCalculatorRequest(
        vehicle_price=data.vehicle_price,
        deposit=data.deposit,
        term_months=data.term_months,
        annual_rate=data.annual_rate
    ))
    app = FinanceApplication(
        **data.model_dump(),
        monthly_payment=calc.monthly_payment
    )
    db.add(app)
    db.commit()
    db.refresh(app)
    return {"id": app.id, "status": app.status,
            "monthly_payment": calc.monthly_payment,
            "message": "Finance application submitted successfully."}


