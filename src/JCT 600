import enum

class FuelType(str, enum.Enum):
    PETROL = "petrol"
    DIESEL = "diesel"
    ELECTRIC = "electric"
    HYBRID = "hybrid"

class VehicleStatus(str, enum.Enum):
    AVAILABLE = "available"
    RESERVED = "reserved"
    SOLD = "sold"

class Vehicle(Base):
    __tablename__ = "vehicles"

    id            = Column(Integer, primary_key=True, index=True)
    make          = Column(String(100), nullable=False)      # e.g. Audi
    model         = Column(String(100), nullable=False)      # e.g. A4
    year          = Column(Integer, nullable=False)
    variant       = Column(String(100))                      # e.g. Sport S Line
    colour        = Column(String(50))
    mileage       = Column(Integer)                          # miles
    price         = Column(Float, nullable=False)            # GBP
    monthly_price = Column(Float)                            # finance monthly
    fuel_type     = Column(Enum(FuelType))
    transmission  = Column(String(50))                       # Manual / Auto
    engine_size   = Column(String(20))                       # e.g. 2.0L
    body_type     = Column(String(50))                       # Saloon, SUV etc.
    doors         = Column(Integer)
    seats         = Column(Integer)
    is_new        = Column(Boolean, default=False)
    dealership    = Column(String(150))                      # Leeds, Bradford etc.
    description   = Column(Text)
    image_url     = Column(String(300))
    status        = Column(Enum(VehicleStatus), default=VehicleStatus.AVAILABLE)
    created_at    = Column(DateTime, default=datetime.utcnow)

    bookings      = relationship("TestDriveBooking", back_populates="vehicle")


